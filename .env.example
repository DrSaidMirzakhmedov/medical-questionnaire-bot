# Скопируйте этот файл в .env и заполните реальными значениями.
# Файл .env никогда не должен попадать в git (см. .gitignore).

# Токен бота, полученный от @BotFather
BOT_TOKEN=

# --- Telegram Payments (необязательно) ---
# Токен провайдера, подключённого через @BotFather -> Payments -> Connect a provider.
# Если оставить пустым — бот работает без шага оплаты (просто пропускает его).
PROVIDER_TOKEN=

# Валюта платежа (трёхбуквенный код, например UZS, USD, RUB)
PAYMENT_CURRENCY=UZS

# Сумма в минимальных единицах валюты (см. комментарий в bot.py).
# 0 = оплата отключена, даже если PROVIDER_TOKEN указан.
PAYMENT_AMOUNT=0

# --- Google Sheets (необязательно) ---
# ID таблицы (часть ссылки между /d/ и /edit)
GOOGLE_SHEET_ID=

# Путь к JSON-файлу сервисного аккаунта Google (не коммитить в git!)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json

# --- Локальное хранилище (всегда используется как основной бэкап) ---
RESPONSES_FILE=responses.jsonl
